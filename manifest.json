{
    "manifest_version": 3,
    "name": "Helper Browser Tool",
    "version": "2.0",
    "description": "Browser Helper Tool",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "tabGroups",
        "scripting",
        "contextMenus",
        "sidePanel",
        "alarms",
        "notifications"
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "features/sticky-note/sticky-note.js"
            ],
            "css": [
                "features/sticky-note/sticky-note.css"
            ]
        }
    ],
    "side_panel": {
        "default_path": "features/note/note-sidebar.html"
    },
    "icons": {
        "48": "icon-48x48.png",
        "72": "icon-72x72.png",
        "96": "icon-72x72.png",
        "128": "icon-128x128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "48": "icon-48x48.png",
            "72": "icon-72x72.png"
        },
        "default_title": "Browser Helper Tool"
    },
    "background": {
        "service_worker": "background.js"
    }
}